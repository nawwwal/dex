{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["overall_pass", "score", "checks", "summary"],
  "properties": {
    "overall_pass": {
      "type": "boolean"
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "pass", "evidence"],
        "properties": {
          "id": {
            "type": "string"
          },
          "pass": {
            "type": "boolean"
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "string"
    }
  }
}
