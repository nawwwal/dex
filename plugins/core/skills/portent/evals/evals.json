{
  "skill_name": "portent",
  "version": 2,
  "notes": "Common-use Portent evals for Aditya's vault. The suite tests whether an agent uses Portent naturally in the middle of real tasks: chooses the right qmd mode, reads source text, writes durable knowledge, updates existing notes, and handles degraded retrieval honestly. Agent-under-test prompts must not include judge-only criteria.",
  "judge_contract": {
    "strategy": "rubric-based outcome evaluation",
    "output_format": {
      "overall_score": "0-1",
      "passed": "boolean",
      "dimensions": {
        "<dimension>": {
          "score": "0-3",
          "evidence": "quote or artifact reference",
          "feedback": "short fix if not full score"
        }
      }
    },
    "pass_threshold": 0.8,
    "scoring": {
      "formula": "sum((dimension_score / 3) * rubric_weight) / sum(rubric_weight)",
      "dimension_scale": {
        "0": "missing or contradicted",
        "1": "mentioned weakly without usable evidence",
        "2": "adequate but incomplete or lightly evidenced",
        "3": "strong, specific, and source-backed"
      },
      "must_include_groups_required": true,
      "must_not_include_violation": "fail"
    }
  },
  "standards": {
    "must": [
      "Choose the qmd mode that fits the task: search for exact anchors, vsearch for semantic recall, query for hybrid reranked synthesis, then get or multi-get source text before factual answers. Do not force every qmd mode by default. Use direct Markdown fallback only when qmd is degraded; do not use Tolaria full-text search.",
      "Read source text with get, multi-get, or direct file read before answering from remembered context.",
      "Update existing Portent objects before creating new ones.",
      "Write durable behavioral, technical, design, team, system, and working-style knowledge when useful.",
      "Treat no update needed as valid only after a writeback audit.",
      "Report qmd, Tolaria, and live-source gaps honestly.",
      "Agent-under-test receives only the natural task prompt, skill path, and task artifacts. expected_behavior, rubric, must_include_any, and must_not_include_any are judge-only and must not be leaked into the tested context.",
      "Run actor evals in an isolated read/write contract: the actor may read only the natural prompt, Portent skill, directly linked Portent references, mock vault/task artifacts, and live tools needed by the task. The actor must not read Codex memory, eval files, hidden rubrics, or broad repo search results that surface eval content.",
      "Actor evals must not mutate the live vault. They must not mutate repo files unless the eval explicitly asks for a repo/skill change; otherwise intended writes go to /tmp/portent-eval/<eval-id> and are judged as dry-run artifacts."
    ],
    "common_sources": [
      "agent-behavior-gotchas",
      "brain-log",
      "portent-index",
      "active-slack-thread-context-map",
      "codex-thread-context-map",
      "aditya-come-back-list",
      "devrev-local-knowledge",
      "agent-studio-pr-actionables",
      "aditya-nawal-voice-and-writing-style",
      "daily-source-backed-agent-studio-digest",
      "agent-studio-analytics-and-observability",
      "agent-marketplace-badge",
      "design-engineering-growth-at-razorpay",
      "admin-dashboard-access-route"
    ]
  },
